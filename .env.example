# Discord Helper Bot Environment Configuration

# Bot Token (REQUIRED)
BOT_TOKEN=your_bot_token_here

# Bot Owner ID
OWNER_ID=your_user_id_here

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=discord_bot
DB_USER=postgres
DB_PASSWORD=your_db_password

# API Keys (Optional)
SELLAUTH_API_KEY=your_sellauth_api_key
WEBHOOK_URL=your_webhook_url

# Bot Configuration
PREFIX=!
EMBED_COLOR=#7289DA
LOG_CHANNEL_ID=your_log_channel_id

# Economy Settings
STARTING_CREDITS=100
DAILY_CREDIT_AMOUNT=50

# Giveaway Settings
GIVEAWAY_MIN_DURATION=1h
GIVEAWAY_MAX_DURATION=7d

# Ticket Settings
TICKET_CATEGORY_ID=your_ticket_category_id
SUPPORT_ROLE_ID=your_support_role_id

# Welcome Settings
WELCOME_CHANNEL_ID=your_welcome_channel_id
WELCOME_MESSAGE=Welcome {user} to {server}!

# Boost Rewards
BOOST_REWARD_CHANNEL_ID=your_boost_channel_id
BOOST_REWARD_AMOUNT=500

# Mystery Box Settings
MYSTERY_BOX_PRICE=100
MYSTERY_BOX_MAX_REWARD=1000
